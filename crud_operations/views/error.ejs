<div class="error-page">
  <div class="error-icon">⚠</div>
  <div class="error-code"><%= statusCode || 500 %></div>
  <h1 class="error-title"><%= title || 'Error' %></h1>
  <p class="error-message"><%= message %></p>

  <% if (typeof details !== 'undefined' && details.length > 0) { %>
  <ul class="error-details">
    <% details.forEach(d => { %>
    <li><strong><%= d.field %>:</strong> <%= d.msg %></li>
    <% }); %>
  </ul>
  <% } %>

  <p class="error-ts text-muted">Timestamp: <%= typeof timestamp !== 'undefined' ? timestamp : new Date().toISOString() %></p>

  <div class="action-bar" style="justify-content:flex-start;margin-top:20px;">
    <a href="/" class="btn btn-primary">← Back to Home</a>
    <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
  </div>
</div>
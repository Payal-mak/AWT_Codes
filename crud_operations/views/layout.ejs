<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Lost &amp; Found</title>
  <style>
    /* ===== RESET ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    /* ===== BASE ===== */
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: #ffffff;
      color: #000000;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ===== NAVBAR ===== */
    nav {
      background: #000000;
      color: #ffffff;
      padding: 14px 30px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    nav .brand {
      font-size: 1.25rem;
      font-weight: 700;
      text-decoration: none;
      color: #ffffff;
      letter-spacing: 0.5px;
    }
    nav .nav-links {
      list-style: none;
      display: flex;
      gap: 24px;
    }
    nav .nav-links a {
      color: #ffffff;
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      padding: 4px 0;
      border-bottom: 2px solid transparent;
      transition: border-color 0.2s;
    }
    nav .nav-links a:hover {
      border-bottom-color: #ffffff;
    }

    /* ===== MAIN ===== */
    main {
      max-width: 960px;
      margin: 30px auto;
      padding: 0 20px;
    }

    h1 {
      font-size: 1.6rem;
      margin-bottom: 20px;
      border-bottom: 2px solid #000;
      padding-bottom: 8px;
    }

    /* ===== TABLE ===== */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    table th, table td {
      border: 1px solid #000;
      padding: 10px 12px;
      text-align: left;
      font-size: 0.9rem;
    }
    table th {
      background: #000;
      color: #fff;
      font-weight: 600;
    }
    table tr:nth-child(even) {
      background: #f5f5f5;
    }

    /* ===== FORMS ===== */
    form.inline { display: inline; }

    .form-group {
      margin-bottom: 16px;
    }
    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 4px;
      font-size: 0.9rem;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #000;
      background: #fff;
      font-size: 0.9rem;
      font-family: inherit;
    }
    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }

    /* ===== BUTTONS ===== */
    .btn {
      display: inline-block;
      padding: 8px 18px;
      font-size: 0.85rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      border: 2px solid #000;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
    }
    .btn-primary {
      background: #000;
      color: #fff;
    }
    .btn-primary:hover {
      background: #333;
    }
    .btn-secondary {
      background: #fff;
      color: #000;
    }
    .btn-secondary:hover {
      background: #eee;
    }
    .btn-danger {
      background: #fff;
      color: #000;
      border-color: #000;
    }
    .btn-danger:hover {
      background: #000;
      color: #fff;
    }
    .btn-sm {
      padding: 4px 10px;
      font-size: 0.8rem;
    }

    /* ===== STATUS BADGES ===== */
    .badge {
      display: inline-block;
      padding: 2px 10px;
      font-size: 0.8rem;
      font-weight: 600;
      border: 1px solid #000;
    }
    .badge-found    { background: #fff; color: #000; }
    .badge-lost     { background: #000; color: #fff; }
    .badge-resolved { background: #ccc; color: #000; }
    .badge-pending  { background: #fff; color: #000; }
    .badge-approved { background: #000; color: #fff; }
    .badge-rejected { background: #ccc; color: #000; }

    /* ===== DETAIL LIST ===== */
    .detail-list dt {
      font-weight: 600;
      margin-top: 10px;
      font-size: 0.9rem;
    }
    .detail-list dd {
      margin-left: 0;
      margin-bottom: 6px;
      padding-left: 12px;
      border-left: 3px solid #000;
      font-size: 0.9rem;
    }

    /* ===== ACTION BAR ===== */
    .action-bar {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
      align-items: center;
    }

    /* ===== FOOTER ===== */
    footer {
      text-align: center;
      padding: 20px;
      border-top: 1px solid #ccc;
      font-size: 0.8rem;
      color: #666;
      margin-top: 40px;
    }

    /* ===== HELPERS ===== */
    .mt-10 { margin-top: 10px; }
    .mb-10 { margin-bottom: 10px; }
    .text-muted { color: #666; }
  </style>
</head>
<body>
  <nav>
    <a class="brand" href="/">Lost &amp; Found</a>
    <ul class="nav-links">
      <li><a href="/items">Items</a></li>
      <li><a href="/claims">Claims</a></li>
    </ul>
  </nav>

  <main>
    <%- body %>
  </main>

  <footer>
    Lost &amp; Found Management System &copy; 2026
  </footer>
</body>
</html>

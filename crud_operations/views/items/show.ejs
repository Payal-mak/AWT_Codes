<h1>
    <%= item.name %>
</h1>

<dl class="detail-list">
    <dt>ID</dt>
    <dd>
        <%= item.id %>
    </dd>

    <dt>Description</dt>
    <dd>
        <%= item.description || 'No description' %>
    </dd>

    <dt>Location Found</dt>
    <dd>
        <%= item.location_found || '—' %>
    </dd>

    <dt>Date Found</dt>
    <dd>
        <%= item.date_found ? new Date(item.date_found).toLocaleDateString() : '—' %>
    </dd>

    <dt>Status</dt>
    <dd><span class="badge badge-<%= item.status %>">
            <%= item.status %>
        </span></dd>

    <dt>Created At</dt>
    <dd>
        <%= new Date(item.created_at).toLocaleString() %>
    </dd>
</dl>

<div class="action-bar mt-10">
    <a href="/items/edit/<%= item.id %>" class="btn btn-secondary btn-sm">Edit</a>
    <form class="inline" method="POST" action="/items/delete/<%= item.id %>"
        onsubmit="return confirm('Delete this item and all its claims?')">
        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
    </form>
    <a href="/claims/add?item_id=<%= item.id %>" class="btn btn-primary btn-sm">+ File a Claim</a>
</div>

<h2 style="margin-top:24px; font-size:1.15rem; border-bottom:1px solid #000; padding-bottom:6px;">Claims for this Item
</h2>

<% if (claims.length===0) { %>
    <p class="text-muted mt-10">No claims filed for this item yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Claimant</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% claims.forEach(claim=> { %>
                    <tr>
                        <td>
                            <%= claim.id %>
                        </td>
                        <td>
                            <%= claim.claimant_name %>
                        </td>
                        <td>
                            <%= claim.contact_info || '—' %>
                        </td>
                        <td><span class="badge badge-<%= claim.claim_status %>">
                                <%= claim.claim_status %>
                            </span></td>
                        <td>
                            <a href="/claims/edit/<%= claim.id %>" class="btn btn-secondary btn-sm">Edit</a>
                            <% if (claim.claim_status==='pending' ) { %>
                                <form class="inline" method="POST" action="/claims/approve/<%= claim.id %>"
                                    onsubmit="return confirm('Approve this claim? The item will be marked as resolved.')">
                                    <button type="submit" class="btn btn-primary btn-sm">Approve</button>
                                </form>
                                <% } %>
                                    <form class="inline" method="POST" action="/claims/delete/<%= claim.id %>"
                                        onsubmit="return confirm('Delete this claim?')">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
        <% } %>

            <a href="/items" class="btn btn-secondary mt-10">← Back to Items</a>